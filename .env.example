# ---- Database (Postgres; Neon / Supabase / Vercel Postgres all work) ----
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ---- Auth (Google sign-in via Auth.js / NextAuth) ----
# AUTH_SECRET: run `openssl rand -base64 32`.
AUTH_SECRET=
# Google OAuth client (console.cloud.google.com -> APIs & Services -> Credentials
# -> OAuth client ID -> Web application). Authorized redirect URI:
#   https://<your-domain>/api/auth/callback/google   (and http://localhost:3000/... for dev)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# One-time: the email that should inherit the pre-existing (owner-less) mugs.
LEGACY_OWNER=
# Local dev only — bypass Google so the app runs without credentials. NEVER set in
# production (ignored on Vercel). Set both to the same email to act as that user.
# DEV_OWNER=you@example.com
# NEXT_PUBLIC_DEV_OWNER=you@example.com

# ---- Gemini (server-side vision + search) ----
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.5-flash

# ---- Defaults ----
DEFAULT_CURRENCY=SEK
DEFAULT_REGION=Sweden

# ---- Tradera API (structured Swedish marketplace listings) ----
# Register an app at https://api.tradera.com -> Application ID + App Key (service key).
# Only these two are needed for public search. Optional but recommended for Sweden.
TRADERA_APP_ID=
TRADERA_APP_KEY=
# TRADERA_SANDBOX=1   # uncomment to hit Tradera's sandbox

# ---- eBay Browse API (structured marketplace listings) ----
# Create an app at https://developer.ebay.com -> get a Client ID / Client Secret.
# Optional.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
# Marketplace to search, e.g. EBAY_GB, EBAY_US, EBAY_DE. (Sweden has no eBay site; pick the nearest.)
EBAY_MARKETPLACE_ID=EBAY_GB
# eBay compliance: a token you choose (32-80 chars, letters/digits/_/-). Required to
# clear your eBay app's "Non Compliant" status via the account-deletion endpoint.
EBAY_VERIFICATION_TOKEN=
# Optional: the exact https URL you register with eBay for account-deletion
# notifications. Defaults to <your-deploy-url>/api/ebay/deletion.
EBAY_DELETION_ENDPOINT=

# ---- Web Push notifications (run `npm run gen-vapid` to generate a keypair) ----
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ---- Cron protection ----
# Set this in Vercel; Vercel Cron sends it automatically as an Authorization header.
CRON_SECRET=
